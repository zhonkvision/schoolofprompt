# ==============================================================================
# PromptShare - Environment Variables Configuration
# ==============================================================================
# 
# Instructions:
# 1. Copy this file to `.env.local`
# 2. Fill in the required values below.
# 3. DO NOT commit `.env.local` to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Vercel Neon Serverless Postgres (Required)
# ------------------------------------------------------------------------------
# Used for storing Analytics events, Sessions, and Security tables.
# You can generate these by connecting a Neon Database to your Vercel Project.
# The main connection string required is POSTGRES_URL.
POSTGRES_URL="postgres://user:password@ep-cool-db-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"
# Other standard Vercel Postgres variables (often auto-injected by Vercel):
POSTGRES_PRISMA_URL="postgres://user:password@ep-cool-db-123456.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgres://user:password@ep-cool-db-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"
POSTGRES_USER="user"
POSTGRES_HOST="ep-cool-db-123456.us-east-2.aws.neon.tech"
POSTGRES_PASSWORD="password"
POSTGRES_DATABASE="neondb"

# ------------------------------------------------------------------------------
# 2. Magic Link Authentication (Required)
# ------------------------------------------------------------------------------
# ADMIN_EMAIL: The sole email address authorized to access the analytics dashboard.
# No other email can log in.
ADMIN_EMAIL="admin@example.com"

# SESSION_SECRET: A strong, highly random secret used to sign JWT Session Tokens.
# Run `openssl rand -base64 32` in your terminal to generate one securely.
# CRITICAL: Do not use weak passwords. If this leaks, sessions can be forged.
SESSION_SECRET="generate_a_secure_random_string_here"

# ------------------------------------------------------------------------------
# 3. Resend Email API (Optional / Required for Login)
# ------------------------------------------------------------------------------
# Required to send Magic Link emails to the admin for Analytics access.
# Get an API key from https://resend.com
RESEND_API_KEY="re_123456789"

# ------------------------------------------------------------------------------
# 4. Vercel KV Redis (Optional / Fallback to InMemory)
# ------------------------------------------------------------------------------
# Used for API Rate Limiting (preventing spam on paste creation).
# If left blank, the app will safely fallback to an InMemory Map structure (which
# works fine for single-instance or small deployments, but clears on reboot).
KV_REST_API_URL="https://your-kv-url.upstash.io"
KV_REST_API_TOKEN="your_kv_token"
